# Python
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# Secrets / credentials — NEVER commit (e.g. borsapy EVDS API key)
.env
.env.*
*.key
*.secret
secrets.*
credentials.*

# Machine-specific / sensitive: combined CA bundle contains local trust-store certs
data/.cache/
*.pem

# Raw & derived financial data — regenerated via `python -m src.fetch` / `src.transform`.
# Bulk raw KAP data stays out of the repo; structure kept via .gitkeep.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
# Exception: the two small derived panels are committed so the live Streamlit
# dashboard (and a fresh clone) works without first running the pipeline.
!data/processed/quarterly_panel.csv
!data/processed/annual_panel.csv

# OS
.DS_Store
Thumbs.db
